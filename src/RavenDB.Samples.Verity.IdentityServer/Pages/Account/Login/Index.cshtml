@page
@model RavenDB.Samples.Verity.IdentityServer.Pages.Account.Login.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Verity — Sign In</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; font-family: system-ui, sans-serif; background: #192d47; color: #e8f0fe; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { background: #1e3a5f; border: 1px solid #2e5c9a; border-radius: 12px; padding: 2rem; width: 100%; max-width: 360px; }
        h1 { margin: 0 0 1.5rem; font-size: 1.5rem; }
        label { display: block; font-size: 0.85rem; color: #93b4d8; margin-bottom: 0.25rem; }
        input[type=text], input[type=password] { width: 100%; padding: 0.6rem 0.75rem; border: 1px solid #2e5c9a; border-radius: 6px; background: #122238; color: #e8f0fe; font-size: 1rem; margin-bottom: 1rem; outline: none; }
        input:focus { border-color: #5b8fd4; }
        button { width: 100%; padding: 0.7rem; background: #2e5c9a; border: none; border-radius: 6px; color: #e8f0fe; font-size: 1rem; cursor: pointer; }
        button:hover { background: #3a70b8; }
        .footer { margin-top: 1rem; font-size: 0.85rem; color: #93b4d8; text-align: center; }
        .footer a { color: #5b8fd4; text-decoration: none; }
        .footer a:hover { text-decoration: underline; }
        .error { color: #f87171; font-size: 0.85rem; margin-bottom: 0.75rem; }
        .success { color: #4ade80; font-size: 0.85rem; margin-bottom: 0.75rem; background: rgba(74,222,128,.08); border: 1px solid rgba(74,222,128,.3); border-radius: 6px; padding: 0.5rem 0.75rem; }
    </style>
</head>
<body>
<div class="card">
    <h1>Verity Sign In</h1>

    @if (Model.Registered)
    {
        <div class="success">Account created — you can sign in now.</div>
    }

    <form method="post">
        @if (Model.ErrorMessage != null)
        {
            <div class="error">@Model.ErrorMessage</div>
        }
        <input type="hidden" asp-for="Input.ReturnUrl" />

        <label asp-for="Input.Username">Username</label>
        <input asp-for="Input.Username" autocomplete="username" autofocus />

        <label asp-for="Input.Password">Password</label>
        <input asp-for="Input.Password" type="password" autocomplete="current-password" />

        <button type="submit">Sign In</button>
    </form>

    <div class="footer">
        No account? <a href="/Account/Register">Create one</a>
    </div>
</div>
</body>
</html>
