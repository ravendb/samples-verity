{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Duende.Bff": "Information",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.TokenType": "None",
          "Duende.Bff.Yarp.AntiforgeryCheck": "true"
        }
      },
      "frontend-route": {
        "ClusterId": "frontend-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:7071/"
          }
        }
      },
      "frontend-cluster": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5173/"
          }
        }
      }
    }
  }
}
